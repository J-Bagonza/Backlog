# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase project settings -> API -> service_role key (SECRET, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Name of the storage bucket you create for photos
SUPABASE_BUCKET=photos

# A password of your choosing that protects the upload endpoint/page.
# Send it as the "x-upload-secret" header when calling /api/upload
UPLOAD_SECRET=choose-a-long-random-string
